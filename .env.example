# 生产环境配置
NODE_ENV=production
API_HOST=0.0.0.0
# 浏览器版与 Windows 桌面壳统一通过 localhost:3001 访问
API_PORT=3001
DATABASE_PATH=./data/app.db
LOG_LEVEL=info

# Anthropic API 配置（二选一）
# 方式1：直接使用 API Key
# ANTHROPIC_API_KEY=sk-ant-...
# 方式2：使用 Claude Code 的认证令牌和代理地址（复用 ~/.claude/settings.json 配置）
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=

# Claude CLI 路径（可选，默认自动查找）
# CLAUDE_BIN=
