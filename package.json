{
  "name": "workhorse-station",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "NODE_ENV=development pnpm --parallel --filter @workhorse-station/api --filter @workhorse-station/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "desktop:build": "pnpm --filter @workhorse-station/desktop build",
    "desktop:start": "pnpm --filter @workhorse-station/desktop start",
    "desktop:pack": "pnpm --filter @workhorse-station/desktop pack",
    "desktop:dist": "pnpm --filter @workhorse-station/desktop dist"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
