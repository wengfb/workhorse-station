{
  "name": "@workhorse-station/desktop",
  "version": "0.1.0",
  "description": "Workhorse Station — AI 开发管理桌面端",
  "author": "Workhorse Station",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "electron dist/main.js",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder"
  },
  "build": {
    "appId": "com.workhorse.station",
    "productName": "Workhorse Station",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "forceCodeSigning": false,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": null,
      "uninstallerIcon": null
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3"
  }
}
